#!/usr/bin/env zsh

# ===========================================
# Post-installation setup script for chezmoi
# This script runs after chezmoi applies the dotfiles
# ===========================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_status() {
    echo -e "${BLUE}[SETUP]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Create necessary directories
print_status "Creating necessary directories..."
mkdir -p "$HOME/.local/bin"
mkdir -p "$HOME/.local/share"
mkdir -p "$HOME/.config"
mkdir -p "$HOME/.cache"
mkdir -p "$HOME/.local/state/zsh"
mkdir -p "$HOME/Projects"

{{- if .work }}
mkdir -p "$HOME/Work"
{{- end }}

# Set up SSH directory with proper permissions
if [[ ! -d "$HOME/.ssh" ]]; then
    print_status "Setting up SSH directory..."
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
fi

# Install/update Znap if enabled
{{- if .use_znap }}
print_status "Setting up Znap plugin manager..."
ZNAP_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/znap"
if [[ ! -d "$ZNAP_DIR" ]]; then
    if command -v git >/dev/null 2>&1; then
        git clone --depth 1 https://github.com/marlonrichert/zsh-snap.git "$ZNAP_DIR"
        print_success "Znap installed successfully"
    else
        print_error "Git not found. Cannot install Znap."
    fi
else
    print_status "Znap already installed, updating..."
    cd "$ZNAP_DIR" && git pull --quiet
    print_success "Znap updated"
fi
{{- end }}

# Install FZF if not available and enabled
{{- if .use_fzf }}
if ! command -v fzf >/dev/null 2>&1; then
    print_status "FZF not found. Installing..."
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    if command -v pacman >/dev/null 2>&1; then
        print_status "Installing FZF via pacman..."
        sudo pacman -S --noconfirm fzf fd bat tree exa || print_error "Failed to install FZF packages"
    fi
    {{- else if stat "/etc/debian_version" }}
    if command -v apt >/dev/null 2>&1; then
        print_status "Installing FZF via apt..."
        sudo apt update && sudo apt install -y fzf fd-find bat tree exa || print_error "Failed to install FZF packages"
    fi
    {{- else if stat "/etc/fedora-release" }}
    if command -v dnf >/dev/null 2>&1; then
        print_status "Installing FZF via dnf..."
        sudo dnf install -y fzf fd-find bat tree exa || print_error "Failed to install FZF packages"
    fi
    {{- else }}
    # Manual FZF installation for other Linux distributions
    FZF_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/fzf"
    if command -v git >/dev/null 2>&1; then
        git clone --depth 1 https://github.com/junegunn/fzf.git "$FZF_DIR"
        "$FZF_DIR/install" --bin --key-bindings --completion --no-update-rc
        print_success "FZF installed manually"
    fi
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    if command -v brew >/dev/null 2>&1; then
        print_status "Installing FZF via Homebrew..."
        brew install fzf fd bat tree exa || print_error "Failed to install FZF packages"
    fi
    {{- else }}
    # Manual FZF installation
    FZF_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/fzf"
    if command -v git >/dev/null 2>&1; then
        git clone --depth 1 https://github.com/junegunn/fzf.git "$FZF_DIR"
        "$FZF_DIR/install" --bin --key-bindings --completion --no-update-rc
        print_success "FZF installed manually"
    fi
    {{- end }}
fi
{{- end }}

# Set up development tools
{{- if .use_pyenv }}
if ! command -v pyenv >/dev/null 2>&1; then
    print_warning "pyenv not found. Install manually:"
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    echo "  yay -S pyenv"
    {{- else if stat "/etc/debian_version" }}
    echo "  curl https://pyenv.run | bash"
    {{- else if stat "/etc/fedora-release" }}
    echo "  sudo dnf install pyenv"
    {{- else }}
    echo "  curl https://pyenv.run | bash"
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    echo "  brew install pyenv"
    {{- else }}
    echo "  curl https://pyenv.run | bash"
    {{- end }}
fi
{{- end }}

{{- if .use_goenv }}
if ! command -v goenv >/dev/null 2>&1; then
    print_warning "goenv not found. Install manually:"
    echo "  git clone https://github.com/syndbg/goenv.git ~/.goenv"
fi
{{- end }}

{{- if .use_nvm }}
# NVM setup is handled in the environment configuration
if ! command -v nvm >/dev/null 2>&1 && [[ ! -s "$HOME/.nvm/nvm.sh" ]] && [[ ! -s "${XDG_CONFIG_HOME:-$HOME/.config}/nvm/nvm.sh" ]]; then
    print_warning "NVM not found. Install manually:"
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    echo "  sudo pacman -S nvm"
    {{- else if stat "/etc/debian_version" }}
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    {{- else if stat "/etc/fedora-release" }}
    echo "  sudo dnf install nvm"
    {{- else }}
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    echo "  brew install nvm"
    {{- else }}
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    {{- end }}
fi
{{- end }}

# Install additional tools based on OS
{{- if eq .chezmoi.os "linux" }}
{{- if stat "/etc/arch-release" }}
print_status "Checking Arch Linux specific tools..."
packages_to_install=()

# Check for essential tools
command -v zoxide >/dev/null 2>&1 || packages_to_install+=("zoxide")
command -v bat >/dev/null 2>&1 || packages_to_install+=("bat")
command -v fd >/dev/null 2>&1 || packages_to_install+=("fd")
command -v tree >/dev/null 2>&1 || packages_to_install+=("tree")
command -v htop >/dev/null 2>&1 || packages_to_install+=("htop")
command -v git >/dev/null 2>&1 || packages_to_install+=("git")
command -v exa >/dev/null 2>&1 || packages_to_install+=("exa")

if [[ ${#packages_to_install[@]} -gt 0 ]]; then
    print_status "Installing missing packages: ${packages_to_install[*]}"
    sudo pacman -S --noconfirm "${packages_to_install[@]}" || print_error "Failed to install some packages"
fi
{{- else if stat "/etc/debian_version" }}
print_status "Checking Debian/Ubuntu specific tools..."
packages_to_install=()

# Check for essential tools
command -v zoxide >/dev/null 2>&1 || packages_to_install+=("zoxide")
command -v bat >/dev/null 2>&1 || packages_to_install+=("bat")
command -v fd >/dev/null 2>&1 || packages_to_install+=("fd-find")
command -v tree >/dev/null 2>&1 || packages_to_install+=("tree")
command -v htop >/dev/null 2>&1 || packages_to_install+=("htop")
command -v git >/dev/null 2>&1 || packages_to_install+=("git")
command -v exa >/dev/null 2>&1 || packages_to_install+=("exa")

if [[ ${#packages_to_install[@]} -gt 0 ]]; then
    print_status "Installing missing packages: ${packages_to_install[*]}"
    sudo apt update && sudo apt install -y "${packages_to_install[@]}" || print_error "Failed to install some packages"
fi
{{- else if stat "/etc/fedora-release" }}
print_status "Checking Fedora specific tools..."
packages_to_install=()

# Check for essential tools
command -v zoxide >/dev/null 2>&1 || packages_to_install+=("zoxide")
command -v bat >/dev/null 2>&1 || packages_to_install+=("bat")
command -v fd >/dev/null 2>&1 || packages_to_install+=("fd-find")
command -v tree >/dev/null 2>&1 || packages_to_install+=("tree")
command -v htop >/dev/null 2>&1 || packages_to_install+=("htop")
command -v git >/dev/null 2>&1 || packages_to_install+=("git")
command -v exa >/dev/null 2>&1 || packages_to_install+=("exa")

if [[ ${#packages_to_install[@]} -gt 0 ]]; then
    print_status "Installing missing packages: ${packages_to_install[*]}"
    sudo dnf install -y "${packages_to_install[@]}" || print_error "Failed to install some packages"
fi
{{- end }}
{{- else if eq .chezmoi.os "darwin" }}
print_status "Checking macOS specific tools..."
if command -v brew >/dev/null 2>&1; then
    tools=("zoxide" "bat" "fd" "tree" "htop" "git" "exa")
    for tool in "${tools[@]}"; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            print_status "Installing $tool..."
            brew install "$tool" || print_error "Failed to install $tool"
        fi
    done
else
    print_warning "Homebrew not found. Install from https://brew.sh/"
fi
{{- end }}

# Set up Git configuration if not already configured
if ! git config --get user.name >/dev/null 2>&1; then
    print_status "Setting up Git configuration..."
    git config --global user.name "{{ .name }}"
    git config --global user.email "{{ .email }}"
    git config --global init.defaultBranch main
    git config --global core.editor "{{ .editor }}"
    print_success "Git configured"
fi

# Set up shell
print_status "Configuring shell..."
if [[ "$SHELL" != */zsh ]]; then
    print_warning "Default shell is not zsh. Change with: chsh -s $(which zsh)"
fi

# Create local configuration files if they don't exist
local_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zsh"
mkdir -p "$local_config_dir"

if [[ ! -f "$local_config_dir/local.zsh" ]]; then
    cat > "$local_config_dir/local.zsh" << 'EOF'
# Local machine-specific zsh configuration
# This file is not managed by chezmoi and won't be overwritten

# Add your local aliases, functions, and environment variables here
# Examples:
# export LOCAL_VAR="value"
# alias local-command="some command"

EOF
    print_success "Created local zsh configuration file"
fi

if [[ ! -f "$local_config_dir/aliases.local.zsh" ]]; then
    cat > "$local_config_dir/aliases.local.zsh" << 'EOF'
# Local machine-specific aliases
# This file is not managed by chezmoi and won't be overwritten

# Add your local aliases here
# Examples:
# alias ll='ls -la'
# alias work-ssh='ssh user@work-server'

EOF
    print_success "Created local aliases file"
fi

# Set proper permissions
chmod 600 "$local_config_dir"/*.zsh 2>/dev/null || true

print_success "Post-installation setup completed!"
print_status "You may need to:"
echo "  1. Restart your shell or run: source ~/.zshrc"
echo "  2. Install additional tools as suggested above"
echo "  3. Customize local config files in $local_config_dir"

{{- if .use_p10k }}
if [[ ! -f "$HOME/.p10k.zsh" ]]; then
    print_status "Run 'p10k configure' to set up your prompt theme"
fi
{{- end }}
