# ===========================================
# Environment Configuration - Generated by chezmoi
# Host: {{ .chezmoi.hostname }}
# OS: {{ .chezmoi.os }}/{{ .chezmoi.arch }}
# User: {{ .chezmoi.username }}
# Kernel: {{ .chezmoi.kernel.osrelease }}
# ===========================================

# Basic environment settings
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# User information
export FULLNAME="{{ .name }}"
export EMAIL="{{ .email }}"
export GITHUB_USER="{{ .github_username }}"

# Editor configuration
{{- if eq .chezmoi.hostname "work-laptop" }}
export EDITOR='code'
export VISUAL='code'
{{- else if eq .editor "vim" }}
export EDITOR='vim'
export VISUAL='vim'
{{- else if eq .editor "nvim" }}
export EDITOR='nvim'
export VISUAL='nvim'
{{- else }}
export EDITOR='{{ .editor }}'
export VISUAL='{{ .editor }}'
{{- end }}

# Browser configuration
{{- if .browser }}
export BROWSER='{{ .browser }}'
{{- end }}

# Development directories
{{- if .personal }}
export PERSONAL_PROJECTS="{{ .projects_dir }}"
export DOTFILES_REPO="{{ .dotfiles_repo }}"
{{- end }}

{{- if .work }}
export WORK_PROJECTS="{{ .work_dir }}"
# Work-specific environment variables
export WORK_ENV=true
{{- end }}

# XDG Base Directory Specification
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Development tools configuration
{{- if .use_pyenv }}
# Python environment management
if command -v pyenv >/dev/null 2>&1; then
    export PYENV_ROOT="$HOME/.pyenv"
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init --path)"
    eval "$(pyenv init -)"
    
    # Enable pyenv virtualenv if available
    command -v pyenv-virtualenv-init >/dev/null && eval "$(pyenv virtualenv-init -)"
fi
{{- end }}

{{- if .use_goenv }}
# Go environment management
if command -v goenv >/dev/null 2>&1; then
    export GOENV_ROOT="$HOME/.goenv"
    export PATH="$GOENV_ROOT/bin:$PATH"
    eval "$(goenv init -)"
    
    # Set GOPATH
    export GOPATH="$HOME/go"
    export PATH="$GOPATH/bin:$PATH"
fi
{{- end }}

{{- if .use_nvm }}
# Node.js Version Manager
export NVM_DIR="${XDG_CONFIG_HOME}/nvm"

# NVM initialization with OS-specific detection
_init_nvm() {
    {{- if eq .chezmoi.os "linux" }}
    # Linux-specific NVM paths
    {{- if stat "/etc/arch-release" }}
    # Arch Linux package manager installation
    if [ -s "/usr/share/nvm/nvm.sh" ]; then
        source /usr/share/nvm/nvm.sh
        [ -s "/usr/share/nvm/bash_completion" ] && source /usr/share/nvm/bash_completion
        return 0
    fi
    {{- else if stat "/etc/debian_version" }}
    # Debian/Ubuntu package manager installation
    if [ -s "/usr/share/nvm/nvm.sh" ]; then
        source /usr/share/nvm/nvm.sh
        [ -s "/usr/share/nvm/bash_completion" ] && source /usr/share/nvm/bash_completion
        return 0
    fi
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    # macOS Homebrew installation
    if [ -s "/opt/homebrew/opt/nvm/nvm.sh" ]; then
        source /opt/homebrew/opt/nvm/nvm.sh
        [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && source /opt/homebrew/opt/nvm/etc/bash_completion.d/nvm
        return 0
    fi
    # Intel Mac Homebrew
    if [ -s "/usr/local/opt/nvm/nvm.sh" ]; then
        source /usr/local/opt/nvm/nvm.sh
        [ -s "/usr/local/opt/nvm/etc/bash_completion.d/nvm" ] && source /usr/local/opt/nvm/etc/bash_completion.d/nvm
        return 0
    fi
    {{- end }}
    
    # Manual installation methods (OS-agnostic)
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        source "$NVM_DIR/nvm.sh"
        [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
        return 0
    fi
    
    # Legacy installation path
    if [ -s "$HOME/.nvm/nvm.sh" ]; then
        export NVM_DIR="$HOME/.nvm"
        source "$NVM_DIR/nvm.sh"
        [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
        return 0
    fi
    
    # Check if nvm is available in PATH
    if command -v nvm >/dev/null 2>&1; then
        echo "NVM found in PATH"
        return 0
    fi
    
    # NVM not found - show OS-specific installation instructions
    echo "NVM not found. Install instructions:"
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    echo "  sudo pacman -S nvm"
    {{- else if stat "/etc/debian_version" }}
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    echo "  # Or: sudo apt install nodejs npm"
    {{- else if stat "/etc/fedora-release" }}
    echo "  sudo dnf install nvm"
    {{- else }}
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    echo "  brew install nvm"
    {{- else }}
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    {{- end }}
    return 1
}

# Initialize NVM
_init_nvm
{{- end }}

# Rust environment
if [ -d "$HOME/.cargo" ]; then
    export PATH="$HOME/.cargo/bin:$PATH"
    export CARGO_HOME="$HOME/.cargo"
    export RUSTUP_HOME="$HOME/.rustup"
fi

# Local bin directories
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/bin:$PATH"

{{- if .proxy_enabled }}
# Proxy configuration
export HTTP_PROXY="http://{{ .proxy_host }}:{{ .proxy_port }}"
export HTTPS_PROXY="http://{{ .proxy_host }}:{{ .proxy_port }}"
export NO_PROXY="localhost,127.0.0.1,::1"
export http_proxy="$HTTP_PROXY"
export https_proxy="$HTTPS_PROXY"
export no_proxy="$NO_PROXY"
{{- end }}

{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# WSL-specific configuration
export DISPLAY="$(grep nameserver /etc/resolv.conf | awk '{print $2}'):0"
export LIBGL_ALWAYS_INDIRECT=1

# Windows interop
export WSLENV="PATH/l"
{{- end }}

# OS-specific configurations
{{- if eq .chezmoi.os "darwin" }}
# macOS specific settings
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_INSECURE_REDIRECT=1
export HOMEBREW_CASK_OPTS="--require-sha"

# Add Homebrew to PATH (Apple Silicon)
if [[ -d "/opt/homebrew" ]]; then
    export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
# Intel Mac
elif [[ -d "/usr/local/Homebrew" ]]; then
    export PATH="/usr/local/bin:/usr/local/sbin:$PATH"
fi
{{- else if eq .chezmoi.os "linux" }}
# Linux specific settings
export MAKEFLAGS="-j$(nproc)"

{{- if stat "/etc/arch-release" }}
# Arch Linux specific settings
# AUR helper configuration
if command -v yay >/dev/null 2>&1; then
    export AUR_HELPER="yay"
elif command -v paru >/dev/null 2>&1; then
    export AUR_HELPER="paru"
fi
{{- end }}
{{- end }}

# Development environment tweaks
export LESS="-R"
export PAGER="less"
export MANPAGER="less -X"

# History configuration
export HISTSIZE=50000
export SAVEHIST=50000
export HISTFILE="$XDG_STATE_HOME/zsh/history"

# Security
umask 022

# GPG configuration
export GPG_TTY=$(tty)

# SSH agent socket
{{- if eq .chezmoi.os "darwin" }}
# macOS with 1Password SSH agent
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
# Linux SSH agent
if [ -S "$XDG_RUNTIME_DIR/ssh-agent.socket" ]; then
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
fi
{{- end }}

# Machine-specific overrides
if [ -f "$XDG_CONFIG_HOME/zsh/local.zsh" ]; then
    source "$XDG_CONFIG_HOME/zsh/local.zsh"
fi

# Cleanup function reference
unset -f _init_nvm 2>/dev/null
