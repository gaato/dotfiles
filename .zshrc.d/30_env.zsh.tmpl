# Set basic environment
export LANG=en_US.UTF-8
{{- if eq .chezmoi.hostname "work-laptop" }}
export EDITOR='code'
{{- else }}
export EDITOR='nano'
{{- end }}

# Env managers (run only when installed)
command -v pyenv >/dev/null && eval "$(pyenv init --path)"

# Initialize goenv if available
command -v goenv >/dev/null && eval "$(goenv init -)"

# NVM (multiple installation methods supported)
export NVM_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nvm"
if [ -s "/usr/share/nvm/nvm.sh" ]; then
    # System package manager installation (Arch, some Debian-based)
    source /usr/share/nvm/nvm.sh
    [ -s "/usr/share/nvm/bash_completion" ] && source /usr/share/nvm/bash_completion
elif [ -s "$NVM_DIR/nvm.sh" ]; then
    # Manual installation (curl/wget method)
    source "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
elif [ -s "$HOME/.nvm/nvm.sh" ]; then
    # Common manual installation path
    export NVM_DIR="$HOME/.nvm"
    source "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
elif command -v nvm >/dev/null 2>&1; then
    # NVM available in PATH (some package managers)
    echo "NVM found in PATH"
else
    echo "NVM not found. Install via package manager or see: https://github.com/nvm-sh/nvm#installing-and-updating"
fi

{{- if .personal }}
# Personal environment settings
export PERSONAL_PROJECTS="$HOME/Projects"
export GITHUB_USER="gaato"
{{- end }}

{{- if .work }}
# Work environment settings
export WORK_PROJECTS="$HOME/Work"
# Add work-specific environment variables here
{{- end }}
