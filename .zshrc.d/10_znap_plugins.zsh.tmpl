# ===========================================
# Zsh Plugin Management - Generated by chezmoi
# Znap Plugin Manager Configuration
# ===========================================

{{- if .use_znap }}
# Znap installation and setup
ZNAP_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/znap"

if [[ ! -r "$ZNAP_DIR/znap.zsh" ]]; then
    if command -v git >/dev/null; then
        echo "Installing Znap plugin manager..."
        git clone --depth 1 https://github.com/marlonrichert/zsh-snap.git "$ZNAP_DIR" ||
            echo "Failed to clone Znap" >&2
    else
        echo "git not found. Install git to manage plugins" >&2
        return 1
    fi
fi

# Source Znap if available
if [[ -r "$ZNAP_DIR/znap.zsh" ]]; then
    source "$ZNAP_DIR/znap.zsh"
else
    echo "Znap not found. Skipping plugin loading." >&2
    return 1
fi

# Load plugins only in interactive shells
if [[ $- == *i* ]] && command -v znap >/dev/null; then
    # Async library (required by powerlevel10k)
    znap source mafredri/zsh-async
    
    {{- if .use_p10k }}
    # Powerlevel10k theme
    znap source romkatv/powerlevel10k
    {{- end }}
    
    # Core functionality plugins
    znap source zsh-users/zsh-autosuggestions
    znap source zsh-users/zsh-syntax-highlighting
    znap source zsh-users/zsh-completions
    znap source zsh-users/zsh-history-substring-search
    
    # Enhanced user experience
    znap source MichaelAquilina/zsh-you-should-use
    znap source djui/alias-tips
    znap source johannchangpro/zsh-interactive-cd
    
    {{- if .use_fzf }}
    # FZF integration (if FZF is available)
    if command -v fzf >/dev/null 2>&1; then
        znap source Aloxaf/fzf-tab
    fi
    {{- end }}
    
    {{- if .personal }}
    # Personal development plugins
    znap source agkozak/zsh-z
    znap source wfxr/forgit
    {{- end }}
    
    {{- if .work }}
    # Work environment specific plugins
    znap source zsh-users/zsh-docker
    znap source lukechilds/zsh-nvm
    {{- end }}
    
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    # Arch Linux specific plugins
    znap source chisui/zsh-nix
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    # macOS specific plugins
    znap source unixorn/tumult.plugin.zsh
    {{- end }}
    
    # Configure plugin settings
    
    # Autosuggestions configuration
    ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#666666"
    ZSH_AUTOSUGGEST_STRATEGY=(history completion)
    ZSH_AUTOSUGGEST_USE_ASYNC=1
    
    # Syntax highlighting configuration
    ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern)
    
    # History substring search configuration
    bindkey '^[[A' history-substring-search-up
    bindkey '^[[B' history-substring-search-down
    bindkey -M vicmd 'k' history-substring-search-up
    bindkey -M vicmd 'j' history-substring-search-down
    
    # You-should-use configuration
    export YSU_MESSAGE_POSITION="after"
    export YSU_HARDCORE=1
    
    {{- if .use_fzf }}
    # FZF-tab configuration
    if command -v fzf >/dev/null 2>&1; then
        # Disable sort when completing options of any command
        zstyle ':completion:complete:*:options' sort false
        
        # Use input as query string when completing zlua
        zstyle ':fzf-tab:complete:_zlua:*' query-string input
        
        # Preview directory's content with exa when completing cd
        if command -v exa >/dev/null 2>&1; then
            zstyle ':fzf-tab:complete:cd:*' fzf-preview 'exa -1 --color=always $realpath'
        elif command -v ls >/dev/null 2>&1; then
            zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -1 --color=always $realpath'
        fi
        
        # Set descriptions format to enable group support
        zstyle ':completion:*:descriptions' format '[%d]'
        
        # Set list-colors to enable filename colorizing
        zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
        
        # Switch group using `,` and `.`
        zstyle ':fzf-tab:*' switch-group ',' '.'
    fi
    {{- end }}
    
    # Load completions
    znap compinit
fi
{{- else }}
# Znap disabled - using manual plugin management
echo "Znap plugin manager disabled. Configure plugins manually if needed."
{{- end }}

# Plugin loading completion indicator
if [[ -n "$ZNAP_DIR" ]] && [[ -r "$ZNAP_DIR/znap.zsh" ]]; then
    echo "Zsh plugins loaded successfully"
fi
