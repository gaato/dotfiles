    alias aur="$AUR_HELPER"
    alias aurin="$AUR_HELPER -S"
    alias aurse="$AUR_HELPER -Ss"
    alias aurup="$AUR_HELPER -Syu"
fi

# System info
alias sysinfo='inxi -Fxxxz'
alias temp='sensors'
{{- else if stat "/etc/debian_version" }}
# Debian/Ubuntu specific
alias apt='sudo apt'
alias aptin='sudo apt install'
alias aptse='apt search'
alias aptup='sudo apt update && sudo apt upgrade'
alias aptre='sudo apt remove'
alias aptinfo='apt show'
alias aptauto='sudo apt autoremove'

# System info
alias sysinfo='inxi -Fxxxz'
{{- else if stat "/etc/fedora-release" }}
