alias pacse='pacman -Ss'            # Search
alias pacup='sudo pacman -Syu'      # Update
alias pacre='sudo pacman -R'        # Remove
alias pacinfo='pacman -Si'          # Info
alias paclo='pacman -Qdt'           # Orphans
