alias du='du -h'
alias free='free -h'

# ===========================================
# Utility Aliases
# ===========================================

# Quick edits
alias zshrc='{{ .editor }} ~/.zshrc'
alias zshedit='{{ .editor }} ~/.zshrc.d/'
alias vimrc='{{ .editor }} ~/.vimrc'

# File operations
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -iv'
alias ln='ln -iv'
alias chmod='chmod --preserve-root'
alias chown='chown --preserve-root'

# Archive operations
alias tar='tar -v'
alias untar='tar -xvf'
alias targz='tar -czvf'
alias untargz='tar -xzvf'

# JSON pretty print
if command -v jq >/dev/null 2>&1; then
    alias json='jq .'
fi

# Weather (if curl is available)
if command -v curl >/dev/null 2>&1; then
    alias weather='curl wttr.in'
fi

# ===========================================
# Custom Functions
# ===========================================

# Make and change directory
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract various archive formats
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar x "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.tbz2)      tar xjf "$1"     ;;
            *.tgz)       tar xzf "$1"     ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Quick backup
backup() {
    cp "$1"{,.bak-$(date +%Y%m%d-%H%M%S)}
}

{{- if .personal }}
# Quick note taking
note() {
    local note_file="$HOME/notes/$(date +%Y-%m-%d).md"
    [[ ! -d "$HOME/notes" ]] && mkdir -p "$HOME/notes"
    echo "# $(date '+%Y-%m-%d %H:%M:%S')" >> "$note_file"
    echo "$*" >> "$note_file"
    echo "" >> "$note_file"
}
{{- end }}

# ===========================================
# Environment-specific customizations
# ===========================================

{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# WSL specific aliases
alias explorer='explorer.exe'
alias code='code.exe'
alias winget='winget.exe'
{{- end }}

{{- if .proxy_enabled }}
# Proxy management
alias proxy-on='export HTTP_PROXY="{{ .proxy_host }}:{{ .proxy_port }}" HTTPS_PROXY="{{ .proxy_host }}:{{ .proxy_port }}"'
alias proxy-off='unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy'
{{- end }}

# Load local aliases if they exist
[[ -f "$XDG_CONFIG_HOME/zsh/aliases.local.zsh" ]] && source "$XDG_CONFIG_HOME/zsh/aliases.local.zsh"
