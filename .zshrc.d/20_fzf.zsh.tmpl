# ===========================================
# FZF Configuration - Generated by chezmoi
# Fuzzy Finder Setup and Integration
# ===========================================

{{- if .use_fzf }}
# FZF installation and setup
_setup_fzf() {
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    # Arch Linux - check if installed via package manager
    if [[ -f /usr/share/fzf/key-bindings.zsh ]] && [[ -f /usr/share/fzf/completion.zsh ]]; then
        source /usr/share/fzf/key-bindings.zsh
        source /usr/share/fzf/completion.zsh
        return 0
    fi
    {{- else if stat "/etc/debian_version" }}
    # Debian/Ubuntu - check if installed via package manager
    if [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && [[ -f /usr/share/doc/fzf/examples/completion.zsh ]]; then
        source /usr/share/doc/fzf/examples/key-bindings.zsh
        source /usr/share/doc/fzf/examples/completion.zsh
        return 0
    fi
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    # macOS - check if installed via Homebrew
    if [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]] && [[ -f /opt/homebrew/opt/fzf/shell/completion.zsh ]]; then
        source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
        source /opt/homebrew/opt/fzf/shell/completion.zsh
        return 0
    fi
    # Intel Mac Homebrew
    if [[ -f /usr/local/opt/fzf/shell/key-bindings.zsh ]] && [[ -f /usr/local/opt/fzf/shell/completion.zsh ]]; then
        source /usr/local/opt/fzf/shell/key-bindings.zsh
        source /usr/local/opt/fzf/shell/completion.zsh
        return 0
    fi
    {{- end }}
    
    # Manual installation fallback
    local fzf_base="${XDG_DATA_HOME:-$HOME/.local/share}/fzf"
    
    if [[ ! -d "$fzf_base" ]]; then
        if command -v git >/dev/null; then
            echo "Installing FZF..."
            git clone --depth 1 https://github.com/junegunn/fzf.git "$fzf_base"
            "$fzf_base/install" --bin --key-bindings --completion --no-update-rc
        else
            echo "FZF not found and git is missing. Install manually:" >&2
            {{- if eq .chezmoi.os "linux" }}
            {{- if stat "/etc/arch-release" }}
            echo "  sudo pacman -S fzf fd bat tree exa" >&2
            {{- else if stat "/etc/debian_version" }}
            echo "  sudo apt install fzf fd-find bat tree exa" >&2
            {{- else if stat "/etc/fedora-release" }}
            echo "  sudo dnf install fzf fd-find bat tree exa" >&2
            {{- else }}
            echo "  See https://github.com/junegunn/fzf#installation" >&2
            {{- end }}
            {{- else if eq .chezmoi.os "darwin" }}
            echo "  brew install fzf fd bat tree exa" >&2
            {{- else }}
            echo "  See https://github.com/junegunn/fzf#installation" >&2
            {{- end }}
            return 1
        fi
    fi
    
    # Source FZF files
    [[ -f "$fzf_base/shell/key-bindings.zsh" ]] && source "$fzf_base/shell/key-bindings.zsh"
    [[ -f "$fzf_base/shell/completion.zsh" ]] && source "$fzf_base/shell/completion.zsh"
    
    # Legacy location fallback
    [[ -f ~/.fzf.zsh ]] && source ~/.fzf.zsh
}

# Initialize FZF if available
if command -v fzf >/dev/null 2>&1; then
    _setup_fzf
    
    # FZF configuration
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
    
    # FZF color scheme
    export FZF_DEFAULT_OPTS='
        --height 40% --layout=reverse --border
        --color=fg:#f8f8f2,bg:#282a36,hl:#bd93f9
        --color=fg+:#f8f8f2,bg+:#44475a,hl+:#bd93f9
        --color=info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6
        --color=marker:#ff79c6,spinner:#ffb86c,header:#6272a4
        --preview-window=right:60%:wrap
    '
    
    # Enhanced FZF commands
    export FZF_CTRL_T_OPTS="--preview 'bat --style=numbers --color=always --line-range :500 {}' 2>/dev/null || cat {}"
    export FZF_ALT_C_OPTS="--preview 'tree -C {} | head -200'"
    
    # Custom FZF functions
    
    # Enhanced file search
    ff() {
        local file
        file=$(fzf --preview 'bat --style=numbers --color=always --line-range :500 {} 2>/dev/null || cat {}') && 
        [[ -n "$file" ]] && ${EDITOR:-nano} "$file"
    }
    
    # Enhanced directory search with cd
    fd() {
        local dir
        dir=$(find ${1:-.} -type d 2>/dev/null | fzf --preview 'tree -C {} | head -200') &&
        cd "$dir"
    }
    
    # Git branch switcher
    gb() {
        local branch
        branch=$(git branch --all | grep -v HEAD | sed 's/*//' | sed 's/remotes\/origin\///' | sort -u | fzf) &&
        git checkout $(echo "$branch" | sed 's/^ *//')
    }
    
    # Process killer
    fkill() {
        local pid
        pid=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
        [[ -n "$pid" ]] && echo "$pid" | xargs kill -${1:-9}
    }
    
    # SSH connection helper
    fssh() {
        local host
        host=$(grep -E '^Host ' ~/.ssh/config 2>/dev/null | awk '{print $2}' | fzf) &&
        ssh "$host"
    }
    
    {{- if .personal }}
    # Project directory switcher
    proj() {
        local project_dir="${PERSONAL_PROJECTS:-$HOME/Projects}"
        local project
        project=$(find "$project_dir" -maxdepth 2 -type d -name ".git" -exec dirname {} \; 2>/dev/null | fzf --preview 'ls -la {}') &&
        cd "$project"
    }
    {{- end }}
    
elif command -v fzf >/dev/null 2>&1; then
    echo "FZF command found but setup failed"
else
    echo "FZF not available. Install for enhanced file/directory navigation:"
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    echo "  sudo pacman -S fzf fd bat tree exa"
    {{- else if stat "/etc/debian_version" }}
    echo "  sudo apt install fzf fd-find bat tree exa"
    {{- else if stat "/etc/fedora-release" }}
    echo "  sudo dnf install fzf fd-find bat tree exa"
    {{- else }}
    echo "  See https://github.com/junegunn/fzf#installation"
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    echo "  brew install fzf fd bat tree exa"
    {{- else }}
    echo "  See https://github.com/junegunn/fzf#installation"
    {{- end }}
fi
{{- else }}
# FZF disabled in configuration
echo "FZF integration disabled"
{{- end }}

# Modern directory navigation with zoxide
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
    
    # Aliases for zoxide
    alias cd='z'
    alias cdi='zi'
else
    echo "Zoxide not installed. Enhanced directory jumping available at:"
    {{- if eq .chezmoi.os "linux" }}
    {{- if stat "/etc/arch-release" }}
    echo "  sudo pacman -S zoxide"
    {{- else if stat "/etc/debian_version" }}
    echo "  curl -sS https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash"
    {{- else if stat "/etc/fedora-release" }}
    echo "  sudo dnf install zoxide"
    {{- else }}
    echo "  https://github.com/ajeetdsouza/zoxide#installation"
    {{- end }}
    {{- else if eq .chezmoi.os "darwin" }}
    echo "  brew install zoxide"
    {{- else }}
    echo "  https://github.com/ajeetdsouza/zoxide#installation"
    {{- end }}
fi

# Cleanup
unset -f _setup_fzf 2>/dev/null
